@using CTMS.DataModel.Models.Systems
@using Syncfusion.Blazor
@using Syncfusion.Blazor.Data
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.Popups
@using Syncfusion.Blazor.Inputs
@using Syncfusion.Blazor.DropDowns
@using Syncfusion.Blazor.Navigations
@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.Calendars
@inject NavigationManager NavigationManager
@inject PatientService PatientService
@inject DropDownListDataService DropDownListDataService
@inject BloodExameService BloodExameService
@inject RandomListService RandomListService
@inject ZipToolService ZipToolService
@inject IJSRuntime JS
@inject RegisterModelService RegisterModelService
@inject PatientService PatientService
@inject MyUserService MyUserService
@inject RoleViewService RoleViewService

<div>
    <div class="card p-3 mb-3">
        <div class="mb-2 fw-bold">LIS WCF API 測試</div>
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Chart No</label>
                <input class="form-control" @bind="ApiTestChartNo" placeholder="請輸入病歷號" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Begin Time / bg</label>
                <input class="form-control" @bind="ApiTestBeginTime" placeholder="例如 20240101" />
            </div>
            <div class="col-md-3">
                <label class="form-label">End Time / ed</label>
                <input class="form-control" @bind="ApiTestEndTime" placeholder="例如 20241231" />
            </div>
            <div class="col-md-3">
                <Button Type="AntDesign.ButtonType.Primary"
                        Loading="@IsApiCalling"
                        OnClick="async () => await OnApi呼叫測試()">
                    呼叫 SYSPOWER API
                </Button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(ApiCallMessage))
        {
            <div class="mt-3 alert alert-info mb-0">@ApiCallMessage</div>
        }

        @if (LabDataResult != null)
        {
            <div class="mt-3 border-top pt-3">
                <h5>@LabDataResult.MethodName</h5>
                @if (!string.IsNullOrWhiteSpace(LabDataResult.ParseMessage))
                {
                    <div class="alert alert-warning">@LabDataResult.ParseMessage</div>
                }

                <details class="mt-3">
                    <summary>展開查詢結果（@LabDataResult.Tables.Count 個資料表）</summary>
                    @foreach (var table in LabDataResult.Tables)
                    {
                        <div class="mt-3">
                            <div class="fw-bold mb-2">資料表：@table.TableName</div>
                            <div class="table-responsive">
                                <table class="table table-sm table-bordered">
                                    <thead>
                                        <tr>
                                            @foreach (var column in table.Columns)
                                            {
                                                <th>@column</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (table.Rows.Count == 0)
                                        {
                                            <tr>
                                                <td colspan="@(Math.Max(table.Columns.Count, 1))">沒有資料</td>
                                            </tr>
                                        }
                                        else
                                        {
                                            @foreach (var row in table.Rows)
                                            {
                                                <tr>
                                                    @foreach (var column in table.Columns)
                                                    {
                                                        <td>@row[column]</td>
                                                    }
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </details>

                <details class="mt-3">
                    <summary>查看 Raw XML</summary>
                    <pre class="mt-2">@LabDataResult.RawXml</pre>
                </details>
            </div>
        }

        @if (TextReportResult != null)
        {
            <div class="mt-3 border-top pt-3">
                <h5>@TextReportResult.MethodName</h5>
                @if (!string.IsNullOrWhiteSpace(TextReportResult.ParseMessage))
                {
                    <div class="alert alert-warning">@TextReportResult.ParseMessage</div>
                }

                <details class="mt-3">
                    <summary>展開查詢結果（@TextReportResult.Tables.Count 個資料表）</summary>
                    @foreach (var table in TextReportResult.Tables)
                    {
                        <div class="mt-3">
                            <div class="fw-bold mb-2">資料表：@table.TableName</div>
                            <div class="table-responsive">
                                <table class="table table-sm table-bordered">
                                    <thead>
                                        <tr>
                                            @foreach (var column in table.Columns)
                                            {
                                                <th>@column</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (table.Rows.Count == 0)
                                        {
                                            <tr>
                                                <td colspan="@(Math.Max(table.Columns.Count, 1))">沒有資料</td>
                                            </tr>
                                        }
                                        else
                                        {
                                            @foreach (var row in table.Rows)
                                            {
                                                <tr>
                                                    @foreach (var column in table.Columns)
                                                    {
                                                        <td>@row[column]</td>
                                                    }
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </details>

                <details class="mt-3">
                    <summary>查看 Raw XML</summary>
                    <pre class="mt-2">@TextReportResult.RawXml</pre>
                </details>
            </div>
        }

        @if (MedicationResult != null)
        {
            <div class="mt-3 border-top pt-3">
                <h5>@MedicationResult.MethodName</h5>
                @if (!string.IsNullOrWhiteSpace(MedicationResult.ParseMessage))
                {
                    <div class="alert alert-warning">@MedicationResult.ParseMessage</div>
                }

                <details class="mt-3">
                    <summary>展開查詢結果（@MedicationResult.Tables.Count 個資料表）</summary>
                    @foreach (var table in MedicationResult.Tables)
                    {
                        <div class="mt-3">
                            <div class="fw-bold mb-2">資料表：@table.TableName</div>
                            <div class="table-responsive">
                                <table class="table table-sm table-bordered">
                                    <thead>
                                        <tr>
                                            @foreach (var column in table.Columns)
                                            {
                                                <th>@column</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (table.Rows.Count == 0)
                                        {
                                            <tr>
                                                <td colspan="@(Math.Max(table.Columns.Count, 1))">沒有資料</td>
                                            </tr>
                                        }
                                        else
                                        {
                                            @foreach (var row in table.Rows)
                                            {
                                                <tr>
                                                    @foreach (var column in table.Columns)
                                                    {
                                                        <td>@row[column]</td>
                                                    }
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </details>

                <details class="mt-3">
                    <summary>查看 Raw XML</summary>
                    <pre class="mt-2">@MedicationResult.RawXml</pre>
                </details>
            </div>
        }
    </div>

    <div>
        <Button Type="AntDesign.ButtonType.Primary" OnClick="async () => await OnFix成大抽血生化eGFR參考區間()">2026/03/26 修正成大的 eGFR參考區間是>=60</Button>
    </div>
    <div class="mt-2">
        <Button Type="AntDesign.ButtonType.Primary" OnClick="async () => await OnFillBloodTestUnits()">補齊既有抽血血液/生化單位</Button>
    </div>

</div>
<DialogBackground />

